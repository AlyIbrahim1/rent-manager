# Core
DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=<Project Settings -> API -> JWT Secret>
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=<Project Settings -> API -> service_role key>
SUPABASE_STORAGE_BUCKET=receipts

# CORS
CORS_ORIGINS=http://localhost:5173
# Dev-only: allows any localhost/127.0.0.1 origin with any port
# Example: http://localhost:3000, http://127.0.0.1:5175
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Dev features
SEED_ENABLED=true
DEV_SESSION_TTL_HOURS=8
DEV_SESSION_CLEANUP_ENABLED=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
